$ORIGIN domain.local.
$TTL 3600
@       IN SOA  ns1.domain.local. hostmaster.domain.local. (
                        2026072201 ; serial (auto-managed by serial-policy: unixtime
                                   ;  once loaded - editing this by hand is fine on
                                   ;  first load only)
                        3600       ; refresh
                        600        ; retry
                        1209600    ; expire (14 days)
                        300 )      ; negative TTL

        IN NS   ns1.domain.local.
        IN NS   ns2.domain.local.

; Master-capable nodes (used as NS targets; clients never query these
; directly through dnsdist - dnsdist's backend pool is A2/A3/B2/B3 only)
ns1     IN A    10.10.10.11
ns2     IN A    10.10.20.11

; Health-check probe record used by dnsdist checkName on every Knot node
_dns-health IN A 127.0.0.1

; --- Example application records --------------------------------------
www     IN A    10.10.10.100
app     IN A    10.10.10.101
